{% extends 'layout-company-contacts.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% from "macros/collapsible-list.njk" import collapsibleList %}

{% set abstractionAlertsHtml %}
  {% if contact.licences.length %}
    <p class="govuk-!-margin-bottom-3">{{ contact.abstractionAlertsLabel }}</p>
    {{ collapsibleList(contact.licences, "Licences") }}
  {% else %}
    <p class="govuk-!-margin-bottom-1">{{ contact.abstractionAlertsLabel }}</p>
  {% endif %}
{% endset %}

{% block pageContent %}
  {{ govukSummaryList({
    rows: [
      {
        key: { text: "Name" },
        value: { text: contact.name }
      },
      {
        key: { text: "Email address" },
        value: { text: contact.email }
      },
      {
        key: { text: "Water abstraction alerts" },
        value: { html: abstractionAlertsHtml }
      },
      {
        key: { text: "Created" },
        value: { text: contact.created }
      },
      {
        key: { text: "Last updated" },
        value: { text: contact.lastUpdated }
      }
    ]
  }) }}

  {% if 'hof_notifications' in roles and additionalContact%}
    <div class="govuk-button-group">
      {{ govukButton({
        text: "Edit contact",
        preventDoubleClick: true,
        href: editContactLink
      }) }}

      {{ govukButton({
        text: "Remove contact",
        classes: "govuk-button--secondary",
        href: removeContactLink,
        preventDoubleClick: true
      }) }}
    </div>
  {% endif %}
{% endblock %}
