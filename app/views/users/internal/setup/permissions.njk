{% extends 'layout.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}

{% block pageContent %}
  <form method="post">
    <input type="hidden" name="wrlsCrumb" value="{{wrlsCrumb}}"/>

    {{ govukRadios({
      name: 'permission',
      errorMessage: error.permission,
      items: [
        {
          checked: permission === 'basic',
          hint: {
            text: "View licences and returns."
          },
          id: "basic",
          text: "Basic access",
          value: "basic"
        },
        {
          checked: permission === 'billing_and_data',
          hint: {
            text: "Send returns communications, monitor statistics and edit data."
          },
          id: "billingAndData",
          text: "Billing and Data",
          value: "billing_and_data"
        },
        {
          checked: permission === 'environment_officer',
          hint: {
            text: "Send hands-off flow notifications."
          },
          id: "environmentOfficer",
          text: "Environment Officer",
          value: "environment_officer"
        },
        {
          checked: permission === 'nps',
          hint: {
            text: "Send renewals."
          },
          id: "nps",
          text: "National Permitting Service",
          value: "nps"
        },
        {
          checked: permission === 'nps_ar_approver',
          hint: {
            text: "Send renewals and digitise licence information and approve changes."
          },
          id: "npsArApprover",
          text: "National Permitting Service and Digitise! approver",
          value: "nps_ar_approver"
        },
        {
          checked: permission === 'nps_ar_user',
          hint: {
            text: "Send renewals and digitise licence information."
          },
          id: "npsArUser",
          text: "National Permitting Service and Digitise! editor",
          value: "nps_ar_user"
        },
        {
          checked: permission === 'psc',
          hint: {
            text: "Send renewals."
          },
          id: "psc",
          text: "Permitting and Support Centre",
          value: "psc"
        },
        {
          checked: permission === 'super',
          hint: {
            text: "Full access to all areas of the service."
          },
          id: "super",
          text: "Super user",
          value: "super"
        } if showSuperPermission === true,
        {
          checked: permission === 'wirs',
          hint: {
            text: "Process returns."
          },
          id: "wirs",
          text: "Waste and Industry Regulatory Service",
          value: "wirs"
        }
      ]
    }) }}

    {{ govukButton({ text: "Continue", preventDoubleClick: true }) }}
  </form>
{% endblock %}
