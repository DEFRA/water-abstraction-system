{% extends 'layout.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% from "macros/user-status-tag.njk" import statusTag %}

{% block pageContent %}
  <p>{{ statusTag(status) }}</p>

  {{ govukSummaryList({
    classes: 'govuk-summary-list--no-border',
    attributes: { 'data-test': 'meta-data' },
    rows: [
      {
        key: { text: "Highest permissions", classes: "meta-data__label" },
        value: { html: '<span data-test="meta-data-permissions">' + permissions + '</span>', classes: "meta-data__value" }
      },
      {
        key: { text: "Last sign in", classes: "meta-data__label" },
        value: { html: '<span data-test="meta-data-last-sign-in">' + lastSignedIn + '</span>', classes: "meta-data__value" }
      }
    ]
  }) }}

  {% if showEditButton %}
    <form method="post">
      <input type="hidden" name="wrlsCrumb" value="{{wrlsCrumb}}"/>

      {{ govukButton({ text: "Edit", preventDoubleClick: true }) }}
    </form>
  {% endif %}

  {% if roles.length === 0 %}
    <p data-test='no-roles-msg'>{{ permissions }} grants no additional roles.</p>
  {% else %}
    {% set rows = [] %}

    {% for role in roles %}
      {% set rowIndex = loop.index0 %}
      {% set tableRow = []%}

      {% set row = [
        {
          attributes: { 'data-test': 'role-name-' + rowIndex },
          text: role.name
        },
        {
          attributes: { 'data-test': 'role-description-' + rowIndex },
          text: role.description
        }
      ] %}

      {% set rows = (rows.push(row), rows) %}
    {% endfor %}

    {{ govukTable({
      attributes: { 'data-test': 'roles-table' },
      caption: "Roles",
      firstCellIsHeader: false,
      head: [
        {
          text: "Name"
        },
        {
          text: "Description"
        }
      ],
      rows: rows
    }) }}
  {% endif %}

  {% if outstandingVerifications.length > 0 %}
    {% set rows = [] %}

    {% for outstandingVerification in outstandingVerifications %}
      {% set rowIndex = loop.index0 %}

      {% if rowIndex > 0 %}
        {% set lastCode = outstandingVerifications[rowIndex - 1].code %}
      {% else %}
        {% set lastCode = null %}
      {% endif %}

      {% set row = []%}

      {% if lastCode !== outstandingVerification.code %}
        {% set codeCell =
          {
            attributes: { 'data-test': 'outstanding-verifications-code-' + rowIndex },
            html: '<span class="govuk-!-font-weight-bold">' + outstandingVerification.code + '</span>',
            rowspan: outstandingVerification.count
          } %}

        {% set row = (row.push(codeCell), row) %}

        {% set createdOnCell =
          {
            attributes: { 'data-test': 'outstanding-verifications-created-at' + rowIndex },
            rowspan: outstandingVerification.count,
            text: outstandingVerification.createdOn
          } %}
        {% set row = (row.push(createdOnCell), row) %}
      {% endif %}

      {% set verificationLicenceLink %}
        <a class="govuk-link" href="{{ outstandingVerification.link }}">{{ outstandingVerification.licenceRef }}</a>
      {% endset %}

      {% set licenceRefCell =
        {
          attributes: { 'data-test': 'outstanding-verifications-licence-ref' + rowIndex },
          html: verificationLicenceLink
        } %}
      {% set row = (row.push(licenceRefCell), row) %}

      {% set licenceHolderCell =
        {
          attributes: { 'data-test': 'outstanding-verifications-licence-holder' + rowIndex },
          text: outstandingVerification.licenceHolder
        } %}
      {% set row = (row.push(licenceHolderCell), row) %}

      {% set rows = (rows.push(row), rows) %}
    {% endfor %}

    {{ govukTable({
      attributes: { 'data-test': 'roles-table' },
      caption: "Outstanding verifications",
      firstCellIsHeader: false,
      head: [
        {
          text: "Code"
        },
        {
          text: "Created on"
        },
        {
          text: "Licence number"
        },
        {
          text: "Licence holder"
        }
      ],
      rows: rows
    }) }}
  {% endif %}

  {% for company in companies %}
    <h2 class="govuk-heading-l govuk-!-margin-bottom-0">{{ company.companyName }}</h2>
    <p>{{ company.mostSignificantRoleName }}</p>
    {% if company.verifications %}
      {% for verification in company.verifications %}
        <p>Security code <span class="govuk-!-font-weight-bold">{{ verification.verificationCode}}</span> sent {{ verification.sent }}</p>
        {% for licence in verification.licences %}
          <p><a href="{{ licence.licenceLink }}">{{ licence.licenceRef }}</a> {{ licence.licenceHolderName }}</p>
        {% endfor %}
      {% endfor %}
    {% endif %}
    {% if company.showLicences %}
      <h3 class="govuk-heading-m govuk-!-margin-bottom-0">{{ company.licences.length }} licences</h3>
      {% set licenceContent %}
        {% for licence in company.licences %}
          <p><a href="{{ licence.licenceLink }}">{{ licence.licenceRef }}</a> {{ licence.licenceHolderName }}</p>
        {% endfor %}
      {% endset %}
      {{ govukDetails({
        classes: "govuk-!-margin-bottom-2",
        html: licenceContent,
        summaryText: "View licences"
      }) }}
    {% endif %}
  {% endfor %}
{% endblock %}
