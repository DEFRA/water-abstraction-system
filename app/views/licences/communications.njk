{% extends 'layout-licences.njk' %}

{% from "govuk/components/pagination/macro.njk" import govukPagination %}

{% from "macros/communications-table.njk" import communicationsTable %}

{% block subPageContent %}
  {% if notifications.length === 0 %}
    <p data-test='no-notifications-msg'>No communications for this licence.</p>
  {% else %}

    {{ communicationsTable(notifications) }}

    {% if pagination.numberOfPages > 1 %}
      {{ govukPagination(pagination.component) }}
    {% endif %}
  {% endif %}
{% endblock %}
