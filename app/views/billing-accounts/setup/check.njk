{% extends 'layout.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% from "macros/new-line-array-items.njk" import newLineArrayItems %}

{% block pageContent %}
  {{ govukSummaryList({
    rows: [
      {
        classes: "govuk-summary-list__row--no-border" if searchInput,
        key: { text: "Billing account" },
        value: { text: accountSelected },
        actions: {
          items: [
            {
              href: links.accountSelected,
              text: "Change",
              visuallyHiddenText: "account selected"
            }
          ]
        }
      },
      {
        classes: "govuk-summary-list__row--no-actions",
        key: { text: "Search term" },
        value: { text: searchInput }
      } if searchInput,
      {
        key: { text: "Existing account" },
        value: { text: existingAccount },
        actions: {
          items: [
            {
              href: links.existingAccount,
              text: "Change",
              visuallyHiddenText: "existing account selected"
            }
          ]
        }
      } if existingAccount,
      {
        classes: "govuk-summary-list__row--no-border" if individualName,
        key: { text: "Account type" },
        value: { text: accountType | capitalize },
        actions: {
          items: [
            {
              href: links.accountType,
              text: "Change",
              visuallyHiddenText: "account type selected"
            }
          ]
        }
      } if accountType,
      {
        classes: "govuk-summary-list__row--no-actions",
        key: { text: "Individual search term" },
        value: { text: individualName }
      } if individualName,
      {
        key: { text: "Company search term" },
        value: { text: companySearch },
        actions: {
          items: [
            {
              href: links.companySearch,
              text: "Change",
              visuallyHiddenText: "company search term"
            }
          ]
        }
      } if companySearch,
      {
        key: { text: "Company name" },
        value: { text: companiesHouseName },
        actions: {
          items: [
            {
              href: links.companiesHouseName,
              text: "Change",
              visuallyHiddenText: "company name"
            }
          ]
        }
      } if companiesHouseName,
      {
        key: { text: "Existing address" },
        value: { html: newLineArrayItems(addressSelected) },
        actions: {
          items: [
            {
              href: links.addressSelected,
              text: "Change",
              visuallyHiddenText: "address selected"
            }
          ]
        }
      } if addressSelected,
      {
        key: { text: "New address" },
        value: { html: newLineArrayItems(address) },
        actions: {
          items: [
            {
              href: links.address,
              text: "Change",
              visuallyHiddenText: "address lookup"
            }
          ]
        }
      } if address.length > 0,
      {
        key: { text: "FAO" },
        value: { text: fao },
        actions: {
          items: [
            {
              href: links.fao,
              text: "Change",
              visuallyHiddenText: "fao"
            }
          ]
        }
      } if fao,
      {
        key: { text: "Contact selected" },
        value: { text: contactSelected },
        actions: {
          items: [
            {
              href: links.contactSelected,
              text: "Change",
              visuallyHiddenText: "contact selected"
            }
          ]
        }
      } if contactSelected,
      {
        key: { text: "Contact Name" },
        value: { text: contactName },
        actions: {
          items: [
            {
              href: links.contactName,
              text: "Change",
              visuallyHiddenText: "contact name"
            }
          ]
        }
      } if contactName
    ]
  }) }}

  <form method="post">
    <input type="hidden" name="wrlsCrumb" value="{{wrlsCrumb}}"/>

    {{ govukButton({ text: "Continue", preventDoubleClick: true }) }}
  </form>
{% endblock %}
