{% extends 'layout.njk' %}

{% from "govuk/components/table/macro.njk" import govukTable %}

{% from "macros/new-line-array-items.njk" import newLineArrayItems %}

{% set tableRows = [] %}

{% for companyAddress in companyAddresses %}
  {% set rowIndex = loop.index0 %}

  {% set tableRow = [
    {
      attributes: { 'data-test': 'company-address-start-date-' + rowIndex },
      text: companyAddress.startDate
    },
    {
      attributes: { 'data-test': 'company-address-end-date-' + rowIndex },
      text: companyAddress.endDate
    },
    {
      attributes: { 'data-test': 'company-address-' + rowIndex },
      html: newLineArrayItems(companyAddress.address)
    }
  ] %}

  {% set tableRows = (tableRows.push(tableRow), tableRows) %}
{% endfor %}


{% block pageContent %}
  <h3 class="govuk-heading-m">Addresses</h3>

  {% if companyAddresses.length === 0 %}
    <p>No addresses found.</p>
  {% else %}
    {{ govukTable({
      caption: pagination.showingMessage,
      head: [
        {
          text: "Start date"
        },
        {
          text: "End date"
        },
        {
          text: "Address"
        }
      ],
      rows: tableRows
    }) }}
  {% endif %}
{% endblock %}
