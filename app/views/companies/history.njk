{% extends 'layout-companies.njk' %}

{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% from "macros/licence-version-change-type-tag.njk" import changeTypeTag as licenceVersionChangeTypeTag %}

{% set tableRows = [] %}

{% for licenceVersion in licenceVersions %}
  {% set rowIndex = loop.index0 %}

  {% if rowIndex > 0 %}
    {% set lastLicenceId = licenceVersions[rowIndex - 1].licenceId %}
  {% else %}
    {% set lastLicenceId = null %}
  {% endif %}

  {% set tableRow = [] %}

  {% if lastLicenceId !== licenceVersion.licenceId %}
    {% set licenceCell =
      {
        attributes: { 'data-test': 'licence-ref-' + rowIndex },
        text: licenceVersion.licenceRef,
        rowspan: licenceVersion.count
      } %}

    {% set tableRow = (tableRow.push(licenceCell), tableRow) %}
  {% endif %}

  {% set startDateCell =
    {
      attributes: { 'data-test': 'start-date-' + rowIndex },
      text: licenceVersion.startDate
    } %}
  {% set tableRow = (tableRow.push(startDateCell), tableRow) %}

  {% set endDateCell =
    {
      attributes: { 'data-test': 'end-date-' + rowIndex },
      text: licenceVersion.endDate
    } %}
  {% set tableRow = (tableRow.push(endDateCell), tableRow) %}

  {% set changeTypeCell =
    {
      attributes: { 'data-test': 'change-type-' + rowIndex },
      html: licenceVersionChangeTypeTag(licenceVersion.changeType, true)
    } %}
  {% set tableRow = (tableRow.push(changeTypeCell), tableRow) %}

  {% set viewLink %}
    <a class="govuk-link" href="{{ licenceVersion.link.href }}">View <span class="govuk-visually-hidden">{{ licenceVersion.link.hiddenText }}</span></a>
  {% endset %}

  {% set actionCell =
    {
      attributes: { 'data-test': 'action-' + rowIndex },
      html: viewLink
    } %}
  {% set tableRow = (tableRow.push(actionCell), tableRow) %}

  {% set tableRows = (tableRows.push(tableRow), tableRows) %}
{% endfor %}


{% block pageContent %}
  {{ govukInsetText({
    text: 'All licence versions linked to this licence holder, past and present.'
  }) }}

  {{ govukTable({
    caption: pagination.showingMessage,
    head: [
      {
        text: "Licence"
      },
      {
        text: "Start date"
      },
      {
        text: "End date"
      },
      {
        text: "Change type"
      },
      {
        text: "Action"
      }
    ],
    rows: tableRows
  }) }}

  {% if pagination.numberOfPages > 1  %}
    {{ govukPagination(pagination.component) }}
  {% endif %}
{% endblock %}
